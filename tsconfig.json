{
    "include": [
        "./src/**/*"
    ],
    "compilerOptions": {
        "strict": true,
        "esModuleInterop": true,
        "lib": [
            "dom",
            "es2015",
            "ES2023"
        ],
        "jsx": "react-jsx",
        "target": "ES2022",         // Изменено с ES2015, чтобы TypeScript понимал современный JS
        "module": "ESNext",         // Добавлено: разрешает использовать import.meta.url
        "moduleResolution": "bundler"
    }
}
